# RC Gateway — Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Supabase Project URL (e.g. https://xyzcompany.supabase.co)
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Supabase Publishable (anon) key — safe to expose in frontend builds
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_XXXXXXXXXXXXXXXXXXXX"

# Supabase Project ID (used by Supabase CLI)
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Update Agent URL (optional — enables OTA updates from dashboard)
# VITE_UPDATE_AGENT_URL="http://your-server:8787"
